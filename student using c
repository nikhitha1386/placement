#include <stdio.h>
struct Student {
    int roll;
    char name[50];
    float marks;
};
int main() {
    struct Student s[100];
    int i = 0, choice;
    float sum = 0;
    while (1) {
        printf("\n--- Student Management System ---\n");
        printf("1. Add Student Marks\n");
        printf("2. Display All Students\n");
        printf("3. Calculate Average\n");
        printf("4. Find Highest Marks\n");
        printf("5. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);
        switch (choice) {
        case 1:
            printf("Enter Roll No: ");
            scanf("%d", &s[i].roll);
            printf("Enter Name: ");
            scanf("%s", s[i].name);
            printf("Enter Marks: ");
            scanf("%f", &s[i].marks);
            i++;
            printf("Student Added!\n");
            break;
        case 2:
            if (i == 0) {
                printf("No students added!\n");
            } else {
                printf("\n--- Student Details ---\n");
                for (int j = 0; j < i; j++) {
                    printf("Roll: %d | Name: %s | Marks: %.2f\n",
                           s[j].roll, s[j].name, s[j].marks);
                }
            }
            break;
        case 3:
            if (i == 0) {
                printf("No students added!\n");
            } else {
                sum = 0;
                for (int j = 0; j < i; j++) {
                    sum += s[j].marks;
                }
                printf("Average Marks = %.2f\n", sum / i);
            }
            break;
        case 4:
            if (i == 0) {
                printf("No students added!\n");
            } else {
                float max = s[0].marks;
                int index = 0;

                for (int j = 1; j < i; j++) {
                    if (s[j].marks > max) {
                        max = s[j].marks;
                        index = j;
                    }
                }
                printf("Highest Marks:\n");
                printf("Roll: %d | Name: %s | Marks: %.2f\n",
                       s[index].roll, s[index].name, s[index].marks);
            }
            break;
        case 5:
            printf("Exiting...\n");
            return 0;

        default:
            printf("Invalid choice!\n");
        }
    }

    return 0;
}
